{
  "baseUrl": "http://127.0.0.1:5173",
  "requireSession": true,
  "viewport": {
    "width": 1400,
    "height": 1200
  },
  "steps": [
    {
      "type": "goto",
      "url": "/mcp-ui/forge-window?windowKey=forecastingCubeBuilder"
    },
    {
      "type": "waitForDomContains",
      "text": "Quick chart",
      "timeoutMs": 60000
    },
    {
      "type": "clickRole",
      "role": "button",
      "name": "Close"
    },
    {
      "type": "fillSelector",
      "selector": "input[type=\"date\"]",
      "index": 0,
      "value": "2026-06-10",
      "timeoutMs": 60000
    },
    {
      "type": "fillSelector",
      "selector": "input[type=\"date\"]",
      "index": 1,
      "value": "2026-06-12",
      "timeoutMs": 60000
    },
    {
      "type": "clickSelector",
      "selector": ".forge-report-builder__chart-action-button--quick",
      "force": true
    },
    {
      "type": "clickText",
      "text": "Overview · Avails by Date and Channel",
      "timeoutMs": 60000
    },
    {
      "type": "waitForEval",
      "expression": "document.querySelectorAll('.forge-report-builder__runtime-preview tbody tr').length > 0",
      "timeoutMs": 60000
    },
    {
      "type": "waitForEval",
      "expression": "(() => { const labels = Array.from(document.querySelectorAll('.forge-report-builder__runtime-preview .forge-dashboard-row-action')).slice(0, 10).map((node) => (node.innerText || node.textContent || '').trim()); return labels.includes('Keep Date') && labels.includes('Exclude Date') && labels.includes('Keep Channel') && labels.includes('Exclude Channel') && labels.includes('Drill to Publisher'); })()",
      "timeoutMs": 60000
    },
    {
      "type": "assertConsoleNotContains",
      "text": "Maximum update depth exceeded"
    },
    {
      "type": "assertConsoleNotContains",
      "text": "Failed to fetch data"
    },
    {
      "type": "screenshot",
      "file": "forecasting-window-live-runtime-table-action-labels-proof.png",
      "fullPage": true
    }
  ]
}
